---
import type { CollectionEntry } from 'astro:content';
import { localizePath, type Locale, type Dict } from '../i18n/ui';
import SectionHeading from './SectionHeading.astro';
import ProjectCard from './ProjectCard.astro';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
  t: Dict;
  entries: CollectionEntry<'projects'>[];
}
const { locale, t, entries } = Astro.props;
---

<section id="projects" class="scroll-mt-20 border-t border-night-line py-14 sm:py-20">
  <div class="reveal">
    <div class="flex flex-wrap items-end justify-between gap-x-8 gap-y-4">
      <SectionHeading title={t.sections.projects} sub={t.sections.projectsSub} />
      <a
        href={localizePath(locale, '/projects/')}
        class="inline-flex items-center gap-1.5 rounded text-sm font-medium text-accent transition-colors hover:text-accent-strong focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
      >
        {t.projects.seeAll}
        <Icon name="arrow-right" class="h-4 w-4" />
      </a>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => <ProjectCard entry={entry} locale={locale} />)}
    </div>
  </div>
</section>
