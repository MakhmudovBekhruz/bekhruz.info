---
import type { Dict } from '../i18n/ui';
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';

interface Props {
  t: Dict;
  profile: {
    email: string;
    phone: string;
    socials: { github: string; linkedin: string; telegram: string };
  };
}
const { t, profile } = Astro.props;

const rows = [
  { href: `mailto:${profile.email}`, label: profile.email, icon: 'mail', external: false },
  { href: `tel:${profile.phone.replace(/[^+\d]/g, '')}`, label: profile.phone, icon: 'phone', external: false },
  { href: profile.socials.telegram, label: 'Telegram', icon: 'telegram', external: true },
  { href: profile.socials.linkedin, label: 'LinkedIn', icon: 'linkedin', external: true },
  { href: profile.socials.github, label: 'GitHub', icon: 'github', external: true },
] as const;

const inputCls =
  'block w-full rounded-lg border border-night-line bg-night-raised px-4 py-3 text-[15px] text-snow placeholder:text-haze transition-colors focus:border-accent-dim focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent';
---

<section id="contact" class="scroll-mt-20 border-t border-night-line py-14 sm:py-20">
  <div class="reveal">
    <SectionHeading title={t.sections.contact} sub={t.sections.contactSub} />

    <div class="mt-10 grid gap-12 md:grid-cols-[minmax(0,2fr)_minmax(0,3fr)]">
      <ul class="space-y-1" role="list">
        {
          rows.map((row) => (
            <li>
              <a
                href={row.href}
                target={row.external ? '_blank' : undefined}
                rel={row.external ? 'noopener noreferrer' : undefined}
                class="-mx-3 flex min-h-11 items-center gap-3.5 rounded-lg px-3 py-2.5 text-[15px] text-mist transition-colors hover:bg-night-raised hover:text-snow focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent"
              >
                <Icon name={row.icon} class="h-4.5 w-4.5 shrink-0 text-haze" />
                {row.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div data-contact-wrap>
        <form
          data-contact
          data-sending={t.contact.sending}
          data-success={t.contact.success}
          data-error={t.contact.error}
          class="space-y-5"
        >
          <div>
            <label for="contact-name" class="mb-1.5 block text-sm font-medium text-mist">{t.contact.nameLabel}</label>
            <input id="contact-name" name="name" type="text" required autocomplete="name" class={inputCls} />
          </div>
          <div>
            <label for="contact-email" class="mb-1.5 block text-sm font-medium text-mist">{t.contact.emailLabel}</label>
            <input id="contact-email" name="email" type="email" required autocomplete="email" class={inputCls} />
          </div>
          <div>
            <label for="contact-message" class="mb-1.5 block text-sm font-medium text-mist"
              >{t.contact.messageLabel}</label
            >
            <textarea id="contact-message" name="message" rows="5" required class={`${inputCls} resize-y`}></textarea>
          </div>

          <div class="hidden" aria-hidden="true">
            <label for="contact-company-url">Company URL</label>
            <input id="contact-company-url" name="company_url" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <button
            type="submit"
            class="inline-flex min-h-11 w-full cursor-pointer items-center justify-center gap-2 rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-night transition-colors hover:bg-accent-strong focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-default disabled:opacity-60 sm:w-auto"
          >
            {t.contact.send}
          </button>
        </form>
        <p data-contact-status role="status" aria-live="polite" class="mt-4 text-sm empty:hidden"></p>
      </div>
    </div>
  </div>
</section>

<script>
  const wrap = document.querySelector<HTMLElement>('[data-contact-wrap]');
  const form = wrap?.querySelector<HTMLFormElement>('form[data-contact]');
  const status = wrap?.querySelector<HTMLParagraphElement>('[data-contact-status]');

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!button) return;
      const original = button.textContent;
      const data = new FormData(form);

      button.disabled = true;
      button.textContent = form.dataset.sending ?? '…';
      status.textContent = '';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: String(data.get('name') ?? ''),
            email: String(data.get('email') ?? ''),
            message: String(data.get('message') ?? ''),
            company_url: String(data.get('company_url') ?? ''),
          }),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.hidden = true;
        status.className = 'mt-4 text-[15px] leading-relaxed text-accent';
        status.textContent = form.dataset.success ?? '';
      } catch {
        status.className = 'mt-4 text-sm text-[oklch(78%_0.09_25)]';
        status.textContent = form.dataset.error ?? '';
        button.disabled = false;
        button.textContent = original;
      }
    });
  }
</script>
