---
import type { CollectionEntry } from 'astro:content';
import type { Dict } from '../i18n/ui';
import SectionHeading from './SectionHeading.astro';

interface Props {
  t: Dict;
  entries: CollectionEntry<'education'>[];
}
const { t, entries } = Astro.props;
---

<section id="education" class="scroll-mt-20 border-t border-night-line py-14 sm:py-18">
  <div class="reveal">
    <SectionHeading title={t.sections.education} sub={t.sections.educationSub} />
    <ul class="mt-8" role="list">
      {
        entries.map((entry) => {
          const e = entry.data;
          return (
            <li class="flex flex-wrap items-baseline justify-between gap-x-8 gap-y-1 border-t border-night-line py-5 first:border-t-0 first:pt-0">
              <div>
                <h3 class="font-display text-lg font-medium tracking-tight text-snow">{e.institution}</h3>
                <p class="mt-1 text-sm text-mist">{e.degree}</p>
              </div>
              <p class="text-sm text-haze tabular-nums">
                {e.from.getFullYear()} – {e.to.getFullYear()}
              </p>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
