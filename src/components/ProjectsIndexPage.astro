---
import Layout from '../layouts/Layout.astro';
import { ui, type Locale } from '../i18n/ui';
import { getByLocale, getProfile } from '../lib/collections';
import Nav from './Nav.astro';
import ProjectCard from './ProjectCard.astro';
import Footer from './Footer.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];

const [profile, projects] = await Promise.all([getProfile(locale), getByLocale('projects', locale)]);
---

<Layout locale={locale} title={t.meta.projectsTitle} description={t.meta.projectsDescription} path="/projects/">
  <Nav locale={locale} path="/projects/" />
  <main id="main" class="mx-auto w-full max-w-5xl px-5 sm:px-8">
    <header class="max-w-2xl pt-12 pb-4 sm:pt-16 animate-rise motion-reduce:animate-none">
      <h1 class="font-display text-3xl font-semibold tracking-tight text-snow sm:text-4xl">
        {t.sections.projects}
      </h1>
      <p class="mt-3 leading-relaxed text-mist">{t.sections.projectsSub}</p>
    </header>
    <div class="grid gap-5 py-10 sm:grid-cols-2 sm:pb-16 lg:grid-cols-3">
      {projects.map((entry, i) => <ProjectCard entry={entry} locale={locale} eager={i < 3} />)}
    </div>
  </main>
  <Footer t={t} profile={profile} />
</Layout>
