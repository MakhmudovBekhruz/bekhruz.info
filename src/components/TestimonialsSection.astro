---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Dict } from '../i18n/ui';
import SectionHeading from './SectionHeading.astro';
import Monogram from './Monogram.astro';
import { resolveAsset } from './images';

interface Props {
  t: Dict;
  entries: CollectionEntry<'testimonials'>[];
}
const { t, entries } = Astro.props;
---

<section id="testimonials" class="scroll-mt-20 border-t border-night-line py-14 sm:py-20">
  <div class="reveal">
    <SectionHeading title={t.sections.testimonials} sub={t.sections.testimonialsSub} />
    <div
      class="carousel -mx-5 mt-10 flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-px-5 px-5 pb-4 sm:-mx-8 sm:scroll-px-8 sm:px-8"
      tabindex="0"
      role="group"
      aria-label={t.sections.testimonials}
    >
      {
        entries.map((entry) => {
          const e = entry.data;
          const photo = resolveAsset(e.image);
          return (
            <figure class="flex w-[86vw] max-w-md shrink-0 snap-start flex-col rounded-xl border border-night-line bg-night-raised p-6 sm:w-[420px] sm:p-7">
              <blockquote class="flex-1 leading-relaxed text-mist">“{e.quote}”</blockquote>
              <figcaption class="mt-6 flex items-center gap-3 border-t border-night-line pt-5">
                {photo ? (
                  <Image
                    src={photo}
                    alt=""
                    width={40}
                    height={40}
                    densities={[1, 2]}
                    class="h-10 w-10 rounded-full border border-night-line object-cover"
                    loading="lazy"
                  />
                ) : (
                  <Monogram text={e.name} class="h-10 w-10 rounded-full text-sm" />
                )}
                <div>
                  <p class="text-sm font-medium text-snow">{e.name}</p>
                  <p class="mt-0.5 text-xs text-haze">
                    {e.role} · {e.company}
                  </p>
                </div>
              </figcaption>
            </figure>
          );
        })
      }
    </div>
  </div>
</section>
