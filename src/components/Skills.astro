---
import type { Dict } from '../i18n/ui';
import SectionHeading from './SectionHeading.astro';
import Chip from './Chip.astro';

interface Props {
  t: Dict;
}
const { t } = Astro.props;

const SKILLS = ['Flutter', 'Dart', 'Bloc', 'Firebase', 'Swift', 'Kotlin', 'Java', 'Spring', 'SQL', 'Git'];
---

<section id="skills" class="scroll-mt-20 border-t border-night-line py-14 sm:py-18">
  <div class="reveal">
    <SectionHeading title={t.sections.skills} sub={t.sections.skillsSub} />
    <ul class="mt-8 flex flex-wrap gap-2.5" role="list">
      {
        SKILLS.map((skill) => (
          <li>
            <Chip>{skill}</Chip>
          </li>
        ))
      }
    </ul>
  </div>
</section>
