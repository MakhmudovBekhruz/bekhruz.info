---
/**
 * Print-ready CV, rendered from the same content collections as the site.
 * scripts/generate-cv.mjs loads this page headlessly after `astro build` and
 * prints it to /cv/bekhruz-makhmudov-cv.pdf — so the CV can never go stale.
 * Excluded from the sitemap (astro.config.mjs) and marked noindex.
 */
import '@fontsource-variable/inter';
import { getByLocale, getProfile } from '../lib/collections';
import skills from '../data/skills.json';

const locale = 'en';
const [profile, experience, education, projects] = await Promise.all([
  getProfile(locale),
  getByLocale('experience', locale),
  getByLocale('education', locale),
  getByLocale('projects', locale),
]);

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
const range = (from: Date, to: Date | null | undefined, current: boolean) =>
  `${fmt.format(from)} – ${current || !to ? 'Present' : fmt.format(to)}`;

const topProjects = projects.slice(0, 6);
const projectLink = (links: { live?: string | null; appStore?: string | null; playStore?: string | null }) =>
  links.live ?? links.appStore ?? links.playStore ?? null;

const generated = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(new Date());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Bekhruz Makhmudov — CV</title>
    <style>
      @page {
        size: A4;
        margin: 14mm 15mm;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }

      body {
        font-family: 'Inter Variable', system-ui, sans-serif;
        font-size: 9.7pt;
        line-height: 1.5;
        color: #1a2130;
        background: #fff;
      }

      main {
        max-width: 180mm;
        margin: 0 auto;
      }

      a {
        color: #0d6a8f;
        text-decoration: none;
      }

      h1 {
        font-size: 21pt;
        font-weight: 750;
        letter-spacing: -0.02em;
      }

      .role {
        margin-top: 2pt;
        font-size: 11pt;
        font-weight: 550;
        color: #0d6a8f;
      }

      .contact {
        margin-top: 6pt;
        display: flex;
        flex-wrap: wrap;
        gap: 3pt 14pt;
        font-size: 8.8pt;
        color: #4a5468;
      }

      section {
        margin-top: 13pt;
      }

      h2 {
        font-size: 10.5pt;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: #0d6a8f;
        border-bottom: 1px solid #d8dde6;
        padding-bottom: 3pt;
        margin-bottom: 7pt;
      }

      .summary {
        color: #333d4f;
      }

      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4pt 5pt;
      }

      .chips span {
        border: 1px solid #d8dde6;
        border-radius: 999px;
        padding: 1.5pt 8pt;
        font-size: 8.6pt;
        color: #333d4f;
      }

      .job {
        break-inside: avoid;
      }

      .job + .job {
        margin-top: 9pt;
      }

      .job-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10pt;
      }

      .job-head h3 {
        font-size: 10.3pt;
        font-weight: 650;
      }

      .dates {
        white-space: nowrap;
        font-size: 8.8pt;
        color: #67718a;
      }

      .job-sub {
        margin-top: 1pt;
        font-size: 9pt;
        color: #4a5468;
      }

      .job ul {
        margin-top: 3.5pt;
        padding-left: 12pt;
        color: #333d4f;
      }

      .job li + li {
        margin-top: 1.5pt;
      }

      .projects {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6pt 14pt;
      }

      .project {
        break-inside: avoid;
      }

      .project h3 {
        font-size: 9.6pt;
        font-weight: 650;
        display: inline;
      }

      .project p {
        display: inline;
        color: #4a5468;
      }

      .edu {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10pt;
      }

      footer {
        margin-top: 13pt;
        font-size: 7.8pt;
        color: #98a1b3;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>{profile.name}</h1>
        <p class="role">Founder &amp; Team Lead · Senior Flutter Developer</p>
        <div class="contact">
          <span>{profile.location}</span>
          <a href={`mailto:${profile.email}`}>{profile.email}</a>
          <span>{profile.phone}</span>
          <a href="https://bekhruz.info">bekhruz.info</a>
          <a href={profile.socials.linkedin}>LinkedIn</a>
          <a href={profile.socials.github}>GitHub</a>
        </div>
      </header>

      <section>
        <h2>Summary</h2>
        <p class="summary">{profile.about}</p>
      </section>

      <section>
        <h2>Skills</h2>
        <div class="chips">{skills.map((s: string) => <span>{s}</span>)}</div>
      </section>

      <section>
        <h2>Experience</h2>
        {
          experience.map((entry) => {
            const e = entry.data;
            return (
              <article class="job">
                <div class="job-head">
                  <h3>{e.title}</h3>
                  <span class="dates">{range(e.from, e.to, e.isCurrent)}</span>
                </div>
                <p class="job-sub">
                  {e.companyUrl ? <a href={e.companyUrl}>{e.company}</a> : e.company} · {e.employmentType} ·{' '}
                  {e.location}
                </p>
                <ul>
                  {e.responsibilities.map((r) => (
                    <li>{r}</li>
                  ))}
                </ul>
              </article>
            );
          })
        }
      </section>

      <section>
        <h2>Selected Projects</h2>
        <div class="projects">
          {
            topProjects.map((entry) => {
              const p = entry.data;
              const link = projectLink(p.links);
              return (
                <div class="project">
                  {link ? <a href={link}><h3>{p.title}</h3></a> : <h3>{p.title}</h3>}
                  <p> — {p.tagline}</p>
                </div>
              );
            })
          }
        </div>
      </section>

      <section>
        <h2>Education</h2>
        {
          education.map((entry) => {
            const e = entry.data;
            return (
              <div class="edu">
                <p>
                  <strong>{e.degree}</strong> — {e.institution}
                </p>
                <span class="dates">{range(e.from, e.to, false)}</span>
              </div>
            );
          })
        }
      </section>

      <footer>Generated from bekhruz.info · {generated}</footer>
    </main>
  </body>
</html>
